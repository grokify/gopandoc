        { "description": "`Geometry` type and `MarginHeaderLines()` for page margin configuration", "commit": "2f0e43a" },
        { "description": "`MarkdownLines()` helper for markdown document generation", "commit": "2f0e43a" },
        { "description": "`WriteFiles()` for writing markdown to multiple output formats", "commit": "2f0e43a" },
        { "description": "CLI helper functions with `ExecSimple()` and `ExecFull()`", "commit": "2f0e43a" }
