{
  "irVersion": "1.0",
  "project": "gopandoc",
  "repository": "https://github.com/grokify/gopandoc",
  "versioning": "semver",
  "commitConvention": "conventional",
  "maintainers": ["grokify", "johncwang@gmail.com"],
  "releases": [
    {
      "version": "v0.4.0",
      "date": "2026-05-11",
      "highlights": [
        { "description": "New `citation` package for bibliographic references with multiple citation styles (Simple, MLA, APA, Chicago)" },
        { "description": "New `citegen` CLI tool for generating formatted reference lists from JSON" }
      ],
      "added": [
        { "description": "`citation` package with `Reference` and `Author` types for bibliographic data", "commit": "bdbf8b9" },
        { "description": "`Collection` type for loading/saving references from JSON with validation", "commit": "bdbf8b9" },
        { "description": "`SimpleFormatter` for readable citation output", "commit": "bdbf8b9" },
        { "description": "`MLAFormatter` for MLA 9th edition citation style", "commit": "bdbf8b9" },
        { "description": "`APAFormatter` for APA 7th edition citation style", "commit": "bdbf8b9" },
        { "description": "`ChicagoFormatter` for Chicago Manual of Style (bibliography and notes)", "commit": "bdbf8b9" },
        { "description": "`FormatMarkdown()` and `FormatMarkdownGrouped()` for markdown output", "commit": "bdbf8b9" },
        { "description": "`citegen` CLI tool using Cobra with `generate`, `validate`, and `tags` subcommands", "commit": "bdbf8b9" },
        { "description": "Tag-based filtering and grouping of references", "commit": "bdbf8b9" }
      ],
      "dependencies": [
        { "description": "Add `github.com/spf13/cobra` v1.10.2 for CLI", "commit": "bdbf8b9" },
        { "description": "Update `github.com/grokify/mogo` to v0.74.4", "commit": "bdbf8b9" }
      ],
      "tests": [
        { "description": "Comprehensive tests for citation package: author formatting, reference validation, formatters", "commit": "bdbf8b9" }
      ],
      "internal": [
        { "description": "Update CI workflow files", "commit": "b0bb606" },
        { "description": "Update LICENSE copyright year", "commit": "bd59ba6" }
      ],
      "documentation": [
        { "description": "Update README.md shields and add citation package documentation", "commit": "86b79ca" }
      ]
    },
    {
